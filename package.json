{
  "name": "internal-swagger-mcp",
  "version": "1.0.5",
  "description": "MCP server for querying internal Swagger API documentation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "internal-swagger-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "serve": "node dist/index.js --http",
    "dev": "tsx watch src/index.ts",
    "dev:serve": "tsx watch src/index.ts --http",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "swagger",
    "openapi",
    "api-docs"
  ],
  "author": "zhangwanli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangwanli09/internal-swagger-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zhangwanli09/internal-swagger-mcp/issues"
  },
  "homepage": "https://github.com/zhangwanli09/internal-swagger-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
